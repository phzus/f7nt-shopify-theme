{% doc %}
  @prompt
    I want to create a 'Fast Pass' section identical to the one in image_c9ec9d.png. It should have 4 columns. Each column needs:
    
    An image at the top (Fast Pass cards).
    
    A pill-shaped badge showing the number of entries and the multiplier (e.g., 500X).
    
    A bold title (BLACK, PLATINUM, GOLD, BRONZE).
    
    A black 'ADD TO CART' button at the bottom.
    The background of the entire section must be light grey or off-white, and the cards should have a white background with rounded corners and a subtle shadow.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fast-pass-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-fast-pass-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-fast-pass-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-fast-pass-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-fast-pass-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_margin_bottom }}px;
  }

  .ai-fast-pass-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-fast-pass-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-fast-pass-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-fast-pass-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    margin-bottom: {{ block.settings.badge_margin_bottom }}px;
    white-space: nowrap;
  }

  .ai-fast-pass-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-fast-pass-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-fast-pass-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 989px) {
    .ai-fast-pass-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-fast-pass-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap | times: 0.75 }}px;
    }
  }
{% endstyle %}

<fast-pass-section-{{ ai_gen_id }} class="ai-fast-pass-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-fast-pass-container-{{ ai_gen_id }}">
    <div class="ai-fast-pass-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign entries_key = 'card_' | append: i | append: '_entries'
          assign multiplier_key = 'card_' | append: i | append: '_multiplier'
          assign title_key = 'card_' | append: i | append: '_title'
          assign button_text_key = 'card_' | append: i | append: '_button_text'
          assign button_link_key = 'card_' | append: i | append: '_button_link'

          assign card_image = block.settings[image_key]
          assign card_entries = block.settings[entries_key]
          assign card_multiplier = block.settings[multiplier_key]
          assign card_title = block.settings[title_key]
          assign card_button_text = block.settings[button_text_key]
          assign card_button_link = block.settings[button_link_key]
        %}

        <div class="ai-fast-pass-card-{{ ai_gen_id }}">
          <div class="ai-fast-pass-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 600 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-fast-pass-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-fast-pass-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if card_entries != blank or card_multiplier != blank %}
            <div class="ai-fast-pass-badge-{{ ai_gen_id }}">
              {% if card_entries != blank %}{{ card_entries }}{% endif %}
              {% if card_entries != blank and card_multiplier != blank %} - {% endif %}
              {% if card_multiplier != blank %}{{ card_multiplier }}{% endif %}
            </div>
          {% endif %}

          {% if card_title != blank %}
            <h3 class="ai-fast-pass-title-{{ ai_gen_id }}">{{ card_title }}</h3>
          {% endif %}

          {% if card_button_text != blank %}
            <a
              href="{{ card_button_link | default: '#' }}"
              class="ai-fast-pass-button-{{ ai_gen_id }}"
            >
              {{ card_button_text }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</fast-pass-section-{{ ai_gen_id }}>

<script>
  (function() {
    class FastPassSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupButtons();
      }

      setupButtons() {
        const buttons = this.querySelectorAll('.ai-fast-pass-button-{{ ai_gen_id }}');
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            if (button.getAttribute('href') === '#') {
              e.preventDefault();
            }
          });
        });
      }
    }

    customElements.define('fast-pass-section-{{ ai_gen_id }}', FastPassSection{{ ai_gen_id }});
  })();
</script>

