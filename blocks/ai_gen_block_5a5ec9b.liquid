{% doc %}
  @prompt
    I need a custom Shopify section for a 'Responsive Clickable Hero'.

    Image Uploads: It must have two separate settings: one for the Desktop Image (DESKTOP.png) and one for the Mobile Image (MOBILE.png).

    Behavior: I do not want any buttons or text overlays from the theme. The entire section must be a clickable link (a single <a> tag wrapping the images) that leads to my collection.

    Responsiveness: Use a media query to show the Desktop image on screens wider than 767px and the Mobile image on screens 767px and below.

    Styling: The images must be full-width (100%), with zero margins or padding in the section. On mobile, ensure the image doesn't look squished by using object-fit: contain or cover based on the aspect ratio of MOBILE.png.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-clickable-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-clickable-hero-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    text-decoration: none;
  }

  .ai-clickable-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    padding: 0;
  }

  .ai-clickable-hero-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-clickable-hero-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-clickable-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    position: relative;
  }

  .ai-clickable-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 400px;
  }

  .ai-clickable-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 767px) {
    .ai-clickable-hero-{{ ai_gen_id }} {
      /* Force zero margin to connect with header */
      margin-top: 0px;
    }

    .ai-clickable-hero-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-clickable-hero-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-clickable-hero-image-{{ ai_gen_id }} {
      object-fit: {{ block.settings.mobile_image_fit }};
    }
  }
{% endstyle %}

<clickable-hero-{{ ai_gen_id }}
  class="ai-clickable-hero-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <a
    href="{{ block.settings.link_url }}"
    class="ai-clickable-hero-link-{{ ai_gen_id }}"
    aria-label="{{ block.settings.link_aria_label }}"
  >
    <div class="ai-clickable-hero-desktop-{{ ai_gen_id }}">
      {% if block.settings.desktop_asset != blank %}
        <img
          src="{{ block.settings.desktop_asset | asset_url }}"
          alt="{{ block.settings.link_aria_label | escape }}"
          loading="lazy"
          class="ai-clickable-hero-image-{{ ai_gen_id }}"
        >
      {% elsif block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-clickable-hero-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-clickable-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-clickable-hero-empty-state-{{ ai_gen_id }}">
            Add a desktop image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-clickable-hero-mobile-{{ ai_gen_id }}">
      {% if block.settings.mobile_asset != blank %}
        <img
          src="{{ block.settings.mobile_asset | asset_url }}"
          alt="{{ block.settings.link_aria_label | escape }}"
          loading="lazy"
          class="ai-clickable-hero-image-{{ ai_gen_id }}"
        >
      {% elsif block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-clickable-hero-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-clickable-hero-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-clickable-hero-empty-state-{{ ai_gen_id }}">
            Add a mobile image
          </div>
        </div>
      {% endif %}
    </div>
  </a>
</clickable-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class ClickableHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('clickable-hero-{{ ai_gen_id }}', ClickableHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Responsive clickable hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Images (Theme assets fallback)"
    },
    {
      "type": "text",
      "id": "desktop_asset",
      "label": "Desktop asset filename",
      "info": "e.g. hero-desktop.png"
    },
    {
      "type": "text",
      "id": "mobile_asset",
      "label": "Mobile asset filename",
      "info": "e.g. hero-mobile.png"
    },
    {
      "type": "select",
      "id": "mobile_image_fit",
      "label": "Mobile image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "link_aria_label",
      "label": "Link description",
      "default": "View collection"
    }
  ],
  "presets": [
    {
      "name": "Responsive clickable hero"
    }
  ]
}
{% endschema %}
