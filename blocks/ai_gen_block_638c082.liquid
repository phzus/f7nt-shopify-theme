{% doc %}
  @prompt
    I need to fix the BMW M4 slider to look exactly like image_2480a3.png.
    
    Slider Layout: On desktop, the section must display 3 images simultaneously in a single row. On mobile, it should show 1 image at a time with a swipe function.
    
    Image Sizing: Force all images in the slider to have a fixed height of 400px on desktop and use object-fit: cover to ensure they align perfectly without being too large.
    
    Navigation: Add the green progress bar/dots indicator exactly as shown in image_2480a3.png, placed between the images and the text.
    
    Text and Button: Maintain the bold italic heading ('THIS LIMITED 2026 BMW M4 COULD BE YOURS'), the 250X entries description, and the centered red button.
    
    Container: Ensure the total width of the 3 images does not exceed the page container, keeping them contained and neat.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bmw-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-bmw-slider-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-bmw-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.4s ease;
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-bmw-slider-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - (2 * {{ block.settings.image_gap }}px)) / 3);
    height: 400px;
    position: relative;
  }

  .ai-bmw-slider-slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-bmw-slider-progress-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: {{ block.settings.progress_margin_top }}px;
    margin-bottom: {{ block.settings.progress_margin_bottom }}px;
  }

  .ai-bmw-slider-dot-{{ ai_gen_id }} {
    width: 40px;
    height: 6px;
    background-color: {{ block.settings.progress_inactive_color }};
    border-radius: 3px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-bmw-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.progress_active_color }};
  }

  .ai-bmw-slider-content-{{ ai_gen_id }} {
    text-align: center;
    margin-top: {{ block.settings.content_margin_top }}px;
  }

  .ai-bmw-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    font-style: {{ block.settings.heading_style }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    line-height: 1.2;
  }

  .ai-bmw-slider-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.description_margin_bottom }}px;
  }

  .ai-bmw-slider-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-bmw-slider-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-bmw-slider-slide-{{ ai_gen_id }} {
      flex: 0 0 100%;
      height: 300px;
    }

    .ai-bmw-slider-track-{{ ai_gen_id }} {
      gap: 0;
    }

    .ai-bmw-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-bmw-slider-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-bmw-slider-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<bmw-slider-{{ ai_gen_id }} class="ai-bmw-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bmw-slider-container-{{ ai_gen_id }}">
    <div class="ai-bmw-slider-track-{{ ai_gen_id }}">
      {% if block.settings.image_1 %}
        <div class="ai-bmw-slider-slide-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_1 | image_url: width: 800 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="800"
            height="400"
          >
        </div>
      {% endif %}

      {% if block.settings.image_2 %}
        <div class="ai-bmw-slider-slide-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_2 | image_url: width: 800 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="800"
            height="400"
          >
        </div>
      {% endif %}

      {% if block.settings.image_3 %}
        <div class="ai-bmw-slider-slide-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_3 | image_url: width: 800 }}"
            alt="{{ block.settings.image_3.alt | escape }}"
            loading="lazy"
            width="800"
            height="400"
          >
        </div>
      {% endif %}

      {% if block.settings.image_4 %}
        <div class="ai-bmw-slider-slide-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_4 | image_url: width: 800 }}"
            alt="{{ block.settings.image_4.alt | escape }}"
            loading="lazy"
            width="800"
            height="400"
          >
        </div>
      {% endif %}

      {% if block.settings.image_5 %}
        <div class="ai-bmw-slider-slide-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_5 | image_url: width: 800 }}"
            alt="{{ block.settings.image_5.alt | escape }}"
            loading="lazy"
            width="800"
            height="400"
          >
        </div>
      {% endif %}

      {% if block.settings.image_6 %}
        <div class="ai-bmw-slider-slide-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image_6 | image_url: width: 800 }}"
            alt="{{ block.settings.image_6.alt | escape }}"
            loading="lazy"
            width="800"
            height="400"
          >
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-bmw-slider-progress-{{ ai_gen_id }}">
    {% assign total_images = 0 %}
    {% if block.settings.image_1 %}{% assign total_images = total_images | plus: 1 %}{% endif %}
    {% if block.settings.image_2 %}{% assign total_images = total_images | plus: 1 %}{% endif %}
    {% if block.settings.image_3 %}{% assign total_images = total_images | plus: 1 %}{% endif %}
    {% if block.settings.image_4 %}{% assign total_images = total_images | plus: 1 %}{% endif %}
    {% if block.settings.image_5 %}{% assign total_images = total_images | plus: 1 %}{% endif %}
    {% if block.settings.image_6 %}{% assign total_images = total_images | plus: 1 %}{% endif %}

    {% for i in (1..total_images) %}
      <div class="ai-bmw-slider-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
    {% endfor %}
  </div>

  <div class="ai-bmw-slider-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-bmw-slider-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <p class="ai-bmw-slider-description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
    {% endif %}

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-bmw-slider-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</bmw-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BmwSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDesktop = window.innerWidth > 749;
        this.startX = 0;
        this.currentX = 0;
        this.isDragging = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-bmw-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-bmw-slider-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-bmw-slider-dot-{{ ai_gen_id }}');
        this.container = this.querySelector('.ai-bmw-slider-container-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.setupEventListeners();
        this.updateSlider();

        window.addEventListener('resize', () => {
          const wasDesktop = this.isDesktop;
          this.isDesktop = window.innerWidth > 749;
          if (wasDesktop !== this.isDesktop) {
            this.currentIndex = 0;
            this.updateSlider();
          }
        });
      }

      setupEventListeners() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            this.currentIndex = parseInt(dot.dataset.index);
            this.updateSlider();
          });
        });

        this.container.addEventListener('touchstart', (e) => this.handleTouchStart(e), { passive: true });
        this.container.addEventListener('touchmove', (e) => this.handleTouchMove(e), { passive: true });
        this.container.addEventListener('touchend', () => this.handleTouchEnd());

        this.container.addEventListener('mousedown', (e) => this.handleMouseDown(e));
        this.container.addEventListener('mousemove', (e) => this.handleMouseMove(e));
        this.container.addEventListener('mouseup', () => this.handleMouseUp());
        this.container.addEventListener('mouseleave', () => this.handleMouseUp());
      }

      handleTouchStart(e) {
        if (this.isDesktop) return;
        this.startX = e.touches[0].clientX;
        this.isDragging = true;
      }

      handleTouchMove(e) {
        if (!this.isDragging || this.isDesktop) return;
        this.currentX = e.touches[0].clientX;
      }

      handleTouchEnd() {
        if (!this.isDragging || this.isDesktop) return;
        this.isDragging = false;

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0 && this.currentIndex < this.slides.length - 1) {
            this.currentIndex++;
          } else if (diff < 0 && this.currentIndex > 0) {
            this.currentIndex--;
          }
          this.updateSlider();
        }
      }

      handleMouseDown(e) {
        if (this.isDesktop) return;
        this.startX = e.clientX;
        this.isDragging = true;
        this.container.style.cursor = 'grabbing';
      }

      handleMouseMove(e) {
        if (!this.isDragging || this.isDesktop) return;
        this.currentX = e.clientX;
      }

      handleMouseUp() {
        if (!this.isDragging || this.isDesktop) return;
        this.isDragging = false;
        this.container.style.cursor = 'grab';

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0 && this.currentIndex < this.slides.length - 1) {
            this.currentIndex++;
          } else if (diff < 0 && this.currentIndex > 0) {
            this.currentIndex--;
          }
          this.updateSlider();
        }
      }

      updateSlider() {
        if (this.isDesktop) {
          this.track.style.transform = 'translateX(0)';
          this.currentIndex = 0;
        } else {
          const offset = -this.currentIndex * 100;
          this.track.style.transform = `translateX(${offset}%)`;
        }

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('bmw-slider-{{ ai_gen_id }}', BmwSlider{{ ai_gen_id }});
  })();
</script>

