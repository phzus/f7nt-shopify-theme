{% doc %}
  @prompt
    I need to create a full-width clickable image banner.
    
    Layout: The section must be edge-to-edge (100% width) with no margins or padding.
    
    Functionality: I don't want a separate button. Instead, make the entire image a clickable link that directs users to my collection page.
    
    Responsiveness: Ensure the image scales correctly on mobile without stretching. On desktop, it should maintain a high-quality aspect ratio (around 600px to 800px height).
    
    Visuals: Add a subtle 'hover' effect where the image slightly zooms in or brightens when the mouse is over it, to signal it is clickable.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-clickable-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-clickable-banner__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
  }

  .ai-clickable-banner__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-clickable-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, filter 0.5s ease;
  }

  .ai-clickable-banner__link-{{ ai_gen_id }}:hover .ai-clickable-banner__image-{{ ai_gen_id }} {
    {% if block.settings.hover_effect == 'zoom' %}
      transform: scale(1.05);
    {% elsif block.settings.hover_effect == 'brighten' %}
      filter: brightness(1.1);
    {% elsif block.settings.hover_effect == 'zoom_brighten' %}
      transform: scale(1.05);
      filter: brightness(1.1);
    {% endif %}
  }

  .ai-clickable-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-clickable-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-clickable-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 24px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  @media screen and (max-width: 749px) {
    .ai-clickable-banner__image-wrapper-{{ ai_gen_id }},
    .ai-clickable-banner__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }
{% endstyle %}

<clickable-banner-{{ ai_gen_id }}
  class="ai-clickable-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.banner_link != blank %}
    <a
      href="{{ block.settings.banner_link }}"
      class="ai-clickable-banner__link-{{ ai_gen_id }}"
      aria-label="{{ block.settings.link_aria_label | default: 'View collection' }}"
    >
      {% if block.settings.banner_image %}
        <div class="ai-clickable-banner__image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.banner_image | image_url: width: 2400 }}"
            alt="{{ block.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_image.width }}"
            height="{{ block.settings.banner_image.height }}"
            class="ai-clickable-banner__image-{{ ai_gen_id }}"
          >
        </div>
      {% else %}
        <div class="ai-clickable-banner__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-clickable-banner__empty-state-{{ ai_gen_id }}">
            Add an image to create your banner
          </div>
        </div>
      {% endif %}
    </a>
  {% else %}
    <div class="ai-clickable-banner__link-{{ ai_gen_id }}">
      {% if block.settings.banner_image %}
        <div class="ai-clickable-banner__image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.banner_image | image_url: width: 2400 }}"
            alt="{{ block.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_image.width }}"
            height="{{ block.settings.banner_image.height }}"
            class="ai-clickable-banner__image-{{ ai_gen_id }}"
          >
        </div>
      {% else %}
        <div class="ai-clickable-banner__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-clickable-banner__empty-state-{{ ai_gen_id }}">
            Add an image and link to create your clickable banner
          </div>
        </div>
      {% endif %}
    </div>
  {% endif %}
</clickable-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ClickableBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const link = this.querySelector('.ai-clickable-banner__link-{{ ai_gen_id }}');
        if (link && link.tagName === 'A') {
          link.addEventListener('keydown', function(event) {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              link.click();
            }
          });
        }
      }
    }

    customElements.define('clickable-banner-{{ ai_gen_id }}', ClickableBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Clickable image banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "text",
      "id": "link_aria_label",
      "label": "Link description",
      "default": "View collection"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop height",
      "default": 600
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile height",
      "default": 400
    },
    {
      "type": "header",
      "content": "Hover effect"
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Effect",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "zoom",
          "label": "Zoom"
        },
        {
          "value": "brighten",
          "label": "Brighten"
        },
        {
          "value": "zoom_brighten",
          "label": "Zoom and brighten"
        }
      ],
      "default": "zoom_brighten"
    }
  ],
  "presets": [
    {
      "name": "Clickable image banner"
    }
  ]
}
{% endschema %}
