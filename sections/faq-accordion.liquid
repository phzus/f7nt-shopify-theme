          }
        },
        {
          "type": "custom_faq_item",
          "settings": {
            "question": "I have a different question, please help!",
            "answer": "<p>We're happy to answer any question you may have! Check out our Help Center for more information on our giveaways, orders, and contact information.</p>",
            "button_text": "VISIT HELP CENTER",
            "button_link": "/pages/contact"
