{{ 'section-image-banner-simple.css' | asset_url | stylesheet_tag }}

<div
  class="image-banner-simple"
  {{ section.shopify_attributes }}
>
  {%- if section.settings.link_url != blank -%}
    <a href="{{ section.settings.link_url }}" class="image-banner-simple__link" aria-label="{{ section.settings.link_aria_label | default: 'Banner' }}">
  {%- endif -%}

  {%- if section.settings.desktop_image != blank -%}
    {%- comment -%} Uses image_picker: Shopify CDN images with srcset {%- endcomment -%}
    <picture>
      {%- if section.settings.mobile_image != blank -%}
        <source
          media="(max-width: 749px)"
          srcset="{{ section.settings.mobile_image | image_url: width: 750 }} 750w,
                  {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w,
                  {{ section.settings.mobile_image | image_url: width: 1500 }} 1500w"
          sizes="100vw"
        >
      {%- endif -%}
      <img
        src="{{ section.settings.desktop_image | image_url: width: 1920 }}"
        srcset="{{ section.settings.desktop_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.desktop_image | image_url: width: 1920 }} 1920w,
                {{ section.settings.desktop_image | image_url: width: 2560 }} 2560w"
        sizes="100vw"
        alt="{{ section.settings.desktop_image.alt | default: section.settings.link_aria_label | escape }}"
        loading="{{ section.settings.lazy_load | default: 'lazy' }}"
        width="{{ section.settings.desktop_image.width }}"
        height="{{ section.settings.desktop_image.height }}"
        class="image-banner-simple__img"
      >
    </picture>

  {%- elsif section.settings.desktop_asset != blank -%}
    {%- comment -%} Fallback: uses asset files from assets/ folder {%- endcomment -%}
    <img
      src="{{ section.settings.desktop_asset | asset_url }}"
      alt="{{ section.settings.link_aria_label | default: 'Banner' | escape }}"
      loading="{{ section.settings.lazy_load | default: 'lazy' }}"
      class="image-banner-simple__img image-banner-simple__img--desktop"
    >
    {%- if section.settings.mobile_asset != blank -%}
      <img
        src="{{ section.settings.mobile_asset | asset_url }}"
        alt="{{ section.settings.link_aria_label | default: 'Banner' | escape }}"
        loading="{{ section.settings.lazy_load | default: 'lazy' }}"
        class="image-banner-simple__img image-banner-simple__img--mobile"
      >
    {%- endif -%}

  {%- else -%}
    <div class="image-banner-simple__placeholder">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {%- endif -%}

  {%- if section.settings.link_url != blank -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Simple image banner",
  "tag": "section",
  "class": "section-image-banner-simple",
  "settings": [
    {
      "type": "header",
      "content": "Images (Shopify Files)"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Images (Theme assets fallback)"
    },
    {
      "type": "text",
      "id": "desktop_asset",
      "label": "Desktop asset filename",
      "info": "e.g. banner-2-desk.png"
    },
    {
      "type": "text",
      "id": "mobile_asset",
      "label": "Mobile asset filename",
      "info": "e.g. banner-2-mob.png"
    },
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "select",
      "id": "lazy_load",
      "label": "Loading behavior",
      "options": [
        {
          "value": "lazy",
          "label": "Lazy (below the fold)"
        },
        {
          "value": "eager",
          "label": "Eager (above the fold)"
        }
      ],
      "default": "lazy"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "link_aria_label",
      "label": "Link description (accessibility)",
      "default": "Banner"
    }
  ],
  "presets": [
    {
      "name": "Simple image banner"
    }
  ]
}
{% endschema %}
