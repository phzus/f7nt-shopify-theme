        "faq_2": {
          "type": "custom_faq_item",
          "settings": {
            "question": "How is the winner selected & notified?",
            "answer": "<p>At the end of each giveaway, all entries are sent to our Federally Compliant Sweepstakes Administrator. They usually take between 1 & 2 weeks to verify and tally all entries, then conduct a random drawing to select a winner.</p>",
            "show_alert": true,
            "alert_content": "<p><strong>BEWARE OF SCAMMERS!</strong><br>Our winners are NEVER notified over Social Media. We call you directly!</p>",
            "show_info_box": false
          }
        },
        "faq_3": {
          "type": "custom_faq_item",
          "settings": {
            "question": "I placed an order, how do I know if I'm entered?",
            "answer": "<p>Once you complete checkout our system will <strong>AUTOMATICALLY RECORD</strong> your entries! Place 1, 2, 3 or even 100 orders, all your entries will be AUTOMATICALLY COMBINED!</p>",
            "show_alert": false,
            "show_info_box": false
          }
        },
        "faq_4": {
          "type": "custom_faq_item",
          "settings": {
            "question": "How do I know if my order has shipped?",
            "answer": "<p>Once your order has shipped you will get a Shipping Confirmation to the email you entered at checkout.</p>",
            "show_alert": false,
            "show_info_box": true,
            "info_title": "PLEASE NOTE",
            "info_content": "If you have not gotten any emails from us after placing your order, it is likely that you mistyped your email address during checkout."
          }
        },
